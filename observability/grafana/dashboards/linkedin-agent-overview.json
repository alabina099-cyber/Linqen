{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Workers Up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(worker_up)", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Total Actions Processed (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(increase(worker_actions_processed_total[24h]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Success Rate (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(worker_actions_succeeded_total[1h])) / clamp_min(sum(increase(worker_actions_processed_total[1h])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Consecutive Errors (max)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 7 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "max(worker_consecutive_errors)", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Actions per minute (success / failed)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum(rate(worker_actions_succeeded_total[5m])) * 60", "legendFormat": "succeeded/min", "refId": "A" },
        { "expr": "sum(rate(worker_actions_failed_total[5m])) * 60", "legendFormat": "failed/min", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Last poll age (ms) per worker",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "worker_last_poll_age_ms", "legendFormat": "{{worker_id}}", "refId": "A" }
      ]
    },
    {
      "type": "logs",
      "title": "Worker logs (errors)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "expr": "{service=\"worker\"} |~ \"(?i)error|exception|failed\"", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["linkedin-agent"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "LinkedIn Agent — Overview",
  "uid": "linkedin-agent-overview",
  "version": 1,
  "weekStart": ""
}
