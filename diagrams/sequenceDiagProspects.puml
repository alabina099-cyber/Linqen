' ===========================================
' ACTEURS & OBJETS
' ===========================================

actor "User" as U <<Actor>>
actor "User (Agent)" as UA <<Actor>>

participant "ProspectsPipeline.tsx" as UI <<UI>>
participant "AgentChat.tsx" as AGUI <<UI>>

participant "GET /api/prospects" as API1 <<API>>
participant "POST /api/prospects" as API2 <<API>>
participant "PATCH /api/prospects/[id]" as API3 <<API>>
participant "DELETE /api/prospects/[id]" as API4 <<API>>
participant "POST /api/prospects/bulk" as API5 <<API>>
participant "POST /api/prospects/update-status" as API6 <<API>>
participant "POST /api/agent/chat" as API7 <<API>>

participant "LinkedInAgent\n(lib/agent.ts)" as AGENT <<Logic>>
participant "ChatOpenAI\n(LangChain)" as LLM <<LLM>>

participant "analyzeProspectTool" as T1 <<Logic>>
participant "searchProspectsDbTool" as T2 <<Logic>>
participant "saveProspectTool" as T3 <<Logic>>
participant "linkedinSearchTool" as T4 <<Logic>>

participant "calculateProspectScore\n(lib/prospectScore.ts)" as SCORE <<Logic>>

participant "Chrome\nExtension" as EXT <<Extension>>

participant "PostgreSQL\n(DB)" as DB <<Data>>

' ===========================================
' SCÉNARIO 1a : AFFICHAGE DU PIPELINE
' ===========================================

== SCÉNARIO 1a : Affichage du Pipeline CRM ==

U -> UI : Ouvre page "Prospects"
activate UI

UI -> API1 : GET /api/prospects
activate API1

API1 -> DB : SELECT p.*,\n  COUNT(m.id) as message_count,\n  MAX(m.created_at) as last_contact\nFROM prospects p\nLEFT JOIN messages m ON p.id = m.prospect_id\nLEFT JOIN users owner ON owner.id = p.user_id\nWHERE user_id IN (scope)\nORDER BY p.score DESC\nLIMIT 50 OFFSET 0
activate DB
DB --> API1 : prospects[]
deactivate DB

API1 -> DB : SELECT COUNT(*) FROM prospects WHERE scope
activate DB
DB --> API1 : total_count
deactivate DB

API1 --> UI : { success, prospects, pagination }
deactivate API1

UI -> UI : organizeProspects(prospects)
note right
    **PipelineStage (6 colonnes) :**
    1. identified  → "Identifiés"
    2. connected  → "Connectés"
    3. contacted  → "Contactés"
    4. responded   → "Réponses"
    5. interested  → "Intéressés"
    6. converted   → "Convertis"
end note

UI --> U : Affiche pipeline avec colonnes
note right of UI #E3F2FD
**Score affiché sur chaque carte :**
- Badge coloré selon le score
- Initiales + nom, rôle, entreprise
- Couleur de bordure selon le statut
end note
deactivate UI

' ===========================================
' SCÉNARIO 1b : AJOUT MANUEL
' ===========================================

newpage

== SCÉNARIO 1b : Ajout Manuel d'un Prospect ==

U -> UI : click("+") dans colonne "Identifiés"
activate UI
UI -> UI : openAddModal('identified')

U -> UI : Remplit formulaire
note right
    **FormData :**
    - name* (requis)
    - role, company, industry
    - location, email, phone
    - linkedin_url
end note

U -> UI : click("Ajouter")
UI -> UI : handleAddProspect()
activate UI

UI -> UI : Validation client
note right
    emailPattern, urlPattern, phonePattern
end note

UI -> UI : stageToStatus['identified'] = 'identified'

UI -> API2 : POST /api/prospects
activate API2

API2 -> API2 : prospectSchema.parse(body)
note right
    **Zod validation :**
    - anti-XSS (SAFE_TEXT regex)
    - URL LinkedIn valide
    - email format valide
    - status ∈ {identified, connected, contacted, responded, interested, converted}
end note

API2 -> SCORE : calculateProspectScore({
    role, company, email, phone,
    location, linkedin_url
  })
activate SCORE

SCORE -> SCORE : getRoleScore(role)
note right
    **Scoring (0-100) :**
    - C-Level : +40
    - VP/Director : +30
    - Manager/Senior : +20
    - Entreprise renseignée : +15
    - Email : +15
    - Téléphone : +10
    - Localisation : +5
    - URL LinkedIn : +5
    - Poste renseigné : +5
end note

SCORE --> API2 : computedScore (0-100)
deactivate SCORE

API2 -> DB : INSERT INTO prospects
note right
    linkedin_url, name, role, company,
    industry, location, company_size,
    email, phone, status='identified',
    score=computedScore,
    notes, user_id,
    created_at=NOW(), updated_at=NOW()
end note
activate DB
DB --> API2 : RETURNING *
deactivate DB

API2 --> UI : { success: true, prospect }
deactivate API2

UI -> UI : Ajoute prospect au state
UI -> UI : organizeProspects(updatedProspects)
UI --> U : Affiche carte dans colonne "Identifiés"
deactivate UI

' ===========================================
' SCÉNARIO 1c : DRAG & DROP
' ===========================================

newpage

== SCÉNARIO 1c : Changement de Statut (Drag & Drop) ==

U -> UI : Drag prospect de "Contactés" vers "Réponses"
activate UI

UI -> UI : handleDragStart(prospect)
UI -> UI : handleDragOver('responded')
UI -> UI : handleDrop(e, 'responded')
activate UI

UI -> UI : Optimistic update
note right
    allProspects.map(p =>
      p.id === dragged.id
        ? { ...p, status: 'responded' }
        : p
    )
    → UI réactive immédiate
end note

UI -> API3 : PATCH /api/prospects/[id]
note right
    body: { status: 'responded' }
end note
activate API3

API3 -> API3 : assertAccess(request, id)
note right
    Vérifie que le user peut
    modifier ce prospect
    (owner ou admin)
end note

API3 -> DB : UPDATE prospects
note right
    SET status = 'responded',
        updated_at = NOW()
    WHERE id = [id]
end note
activate DB
DB --> API3 : RETURNING *
deactivate DB

API3 --> UI : { success: true, prospect }
deactivate API3

UI -> UI : organizeProspects(updatedProspects)
UI --> U : Prospect affiché dans "Réponses"
deactivate UI

alt Erreur réseau
    UI -> UI : fetchProspects(true)
    note right
        Revert : recharge depuis DB
        pour annuler l'optimistic update
    end note
end

' ===========================================
' SCÉNARIO 1d : IMPORT BATCH (Extension)
' ===========================================

newpage

== SCÉNARIO 1d : Import Batch depuis l'Extension Chrome ==

EXT -> API5 : POST /api/prospects/bulk
note right
    Body: {
      prospects: [
        { name, linkedin_url, role, company,
          location, industry, email, phone },
        ...
      ],
      source: 'linkedin_search',
      search_action_id: 123
    }
end note
activate API5

API5 -> API5 : Vérifie auth + body valide

loop Pour chaque prospect dans le batch
    API5 -> API5 : Validation minimale
    note right
        name + linkedin_url requis
        sinon → skipped
    end note

    API5 -> API5 : normalizedUrl = linkedin_url.replace(/\/$/, "")

    API5 -> SCORE : calculateProspectScore(p)
    activate SCORE
    SCORE --> API5 : computedScore
    deactivate SCORE

    API5 -> DB : UPSERT prospects
    note right
        INSERT INTO prospects
        (linkedin_url, name, role, company,
         location, industry, status='identified',
         score, notes, user_id,
         created_at, updated_at)
        VALUES (...)
        ON CONFLICT (linkedin_url) DO UPDATE SET
          name = COALESCE(EXCLUDED.name, prospects.name),
          role = COALESCE(EXCLUDED.role, prospects.role),
          company = COALESCE(EXCLUDED.company, prospects.company),
          score = GREATEST(EXCLUDED.score, prospects.score),
          updated_at = NOW()
        RETURNING *
    end note
    activate DB
    DB --> API5 : prospect row
    deactivate DB

    API5 -> API5 : saved.push(result)
end

API5 --> EXT : { success: true,
                  saved_count, skipped_count,
                  prospects: [...] }
deactivate API5

note over EXT, DB #E0F7FA
**UPSERT par linkedin_url (unique constraint)**
**Le score conservé est le MAX des deux**
**Source notée dans le champ notes**
end note

