== SCÉNARIO 1f : Mise à Jour Statut par l'Extension ==

EXT -> API6 : POST /api/prospects/update-status
note right
    Body: {
      linkedin_url: "https://linkedin.com/in/jean",
      status: "connected",
      name: "Jean Dupont",
      role: "CTO",
      company: "StartupAI"
    }
end note
activate API6

API6 -> API6 : Validation linkedin_url
note right
    Regex: ^https?:\/\/(www\.)?linkedin\.com\/...
    → Anti-XSS / anti-injection
end note

API6 -> API6 : Validation status
note right
    status ∈ {identified, connected, contacted,
              responded, interested, converted}
end note

alt prospect_id fourni
    API6 -> DB : UPDATE prospects
                 SET status = $1,
                     updated_at = NOW()
                 WHERE id = $2
    activate DB
    DB --> API6 : RETURNING *
    deactivate DB
else linkedin_url fourni
    API6 -> DB : UPSERT par URL
    note right
        INSERT INTO prospects
        (linkedin_url, name, role, company,
         industry, location, status, score=50,
         created_at, updated_at)
        VALUES (...)
        ON CONFLICT (linkedin_url) DO UPDATE SET
          status = EXCLUDED.status,
          name = COALESCE(EXCLUDED.name, prospects.name),
          role = COALESCE(EXCLUDED.role, prospects.role),
          company = COALESCE(EXCLUDED.company, prospects.company),
          updated_at = NOW()
        RETURNING *
    end note
    activate DB
    DB --> API6 : RETURNING *
    deactivate DB
end

API6 --> EXT : { success: true, prospect }
deactivate API6

