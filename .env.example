# =============================================
# LinkedIn Agent — Variables d'environnement
# =============================================
# Copiez ce fichier en .env (jamais committé) puis remplissez les valeurs.
# Sur Coolify, ces variables sont injectées via l'UI (Settings > Environment).
# =============================================


# ---- Base de données (Neon PostgreSQL en production) ----
DATABASE_URL=Change_me

# ---- API OpenAI (LLM agent) ----
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Chiffrement des données sensibles (mots de passe LinkedIn, sessions) ----
# Générer avec : openssl rand -base64 32
ENCRYPTION_KEY=change_me_32_bytes_base64_string

# ---- JWT (signature des tokens d'authentification) ----
# Générer avec : openssl rand -base64 64
JWT_SECRET=change_me_long_random_secret_at_least_32_chars

# ---- LinkedIn OAuth 2.0 (Sign In with LinkedIn) ----
# Crée une app sur https://www.linkedin.com/developers/apps
# Scopes requis : openid, profile, email
# Ajoute l'URL de callback dans Auth -> Authorized redirect URLs.
LINKEDIN_CLIENT_ID=change_me
LINKEDIN_CLIENT_SECRET=change_me
# En dev local : http://localhost:3000/api/auth/linkedin/callback
# En prod      : https://linqen.xyz/api/auth/linkedin/callback
LINKEDIN_REDIRECT_URI=https://linqen.xyz/api/auth/linkedin/callback

# ---- Worker ----
WORKER_ID=worker-prod-01
POLL_INTERVAL_MS=5000
HEADLESS=true
HEALTH_PORT=9090

# ---- Métriques Prometheus ----
# Générer avec : openssl rand -hex 32
METRICS_BEARER_TOKEN=change_me_64_hex_chars

# ---- Backups ----
# Passphrase forte pour le chiffrement GPG AES256 des backups
BACKUP_ENCRYPTION_PASSPHRASE=change_me_strong_passphrase
BACKUP_RETENTION_DAYS=30

# ---- Cloudflare R2 (stockage backups) ----
R2_ACCESS_KEY_ID=change_me
R2_SECRET_ACCESS_KEY=change_me
R2_BUCKET=linkedin-agent-backups
R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com

# ---- Coolify (déploiement & rollback) ----
COOLIFY_BASE_URL=https://coolify.example.com
COOLIFY_TOKEN=change_me
COOLIFY_APP_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COOLIFY_WORKER_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COOLIFY_WEBHOOK_URL=https://coolify.example.com/webhooks/xxxxx
COOLIFY_WORKER_WEBHOOK_URL=https://coolify.example.com/webhooks/yyyyy

# ---- Production URL (pour smoke tests et Prometheus scraping) ----
PROD_URL=https://linqen.xyz
PUBLIC_HOST=linqen.xyz

# ---- Grafana (stack observability) ----
# Le démarrage est REFUSÉ si GRAFANA_PASSWORD vaut "admin" ou est manquant
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_strong_password
GRAFANA_ROOT_URL=https://grafana.example.com

# ---- PostgreSQL local (uniquement profile local-db, pas en prod) ----
POSTGRES_USER=linkedin
POSTGRES_PASSWORD=linkedin_dev_pwd
POSTGRES_DB=linkedin_agent

